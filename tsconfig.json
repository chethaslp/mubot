{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "build",
    "target": "es2021",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "lib": ["ES2021.String", "ES2021", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
    },
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
